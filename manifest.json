{
  "manifest_version": 3,
  "name": "WatchedIt",
  "description": "Marca videos de YouTube como vistos con un clic",
  "version": "1.0.0",
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_title": "WatchedIt"
  }
}
